{
    "name": "TFS 2015 Helper",
    "version": "0.0.7",
    "manifest_version": 3,
    "description": "Quality-of-life tweaks for TFS 2015 / VSTS: latest-version / manual-deployment buttons on release creation, dark mode toggle.",
    "homepage_url": "https://github.com/andrewiankidd/BrowserExtensions/tree/master/tfs2015-helper",
    "icons": {
        "16": "icons/logo16.png",
        "48": "icons/logo48.png",
        "128": "icons/logo128.png"
    },
    "action": {
        "default_popup": "main/main.html"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "tfs2015-helper@andrewkidd.co.uk",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [{
        "matches": [
            "http://*/tfs*",
            "https://*/tfs*"
        ],
        "js": [
            "inject/jquery.min.js",
            "inject/linkify.min.js",
            "inject/linkify-jquery.min.js",
            "inject/waitForKeyElements.js",
            "inject/inject.js"
        ],
        "run_at": "document_idle"
    }],
    "web_accessible_resources": [{
        "resources": [
            "inject/darkMode.css"
        ],
        "matches": [
            "http://*/tfs*",
            "https://*/tfs*"
        ]
    }]
}

{
    "name": "Simple Storage Sync",
    "version": "0.0.0.1",
    "manifest_version": 3,
    "description": "An extension to sync site-specific browser storage between machines",
    "homepage_url": "https://github.com/andrewiankidd/BrowserExtensions/tree/master/simple-storage-sync",
	"icons": {
        "16": "icons/logo16.png",
        "32": "icons/logo32.png",
        "48": "icons/logo48.png",
        "128": "icons/logo128.png"
    },
	"action": {
        "default_popup": "main/main.html"
    },
	"browser_specific_settings": {
		"gecko": {
			"id": "simple-storage-sync@andrewkidd.co.uk",
			"strict_min_version": "109.0",
			"data_collection_permissions": {
				"required": ["websiteContent"]
			}
		}
	},
	"host_permissions": [
		"*://*/*"
	],
	"permissions": [
		"storage",
		"tabs",
		"scripting"
	]
}
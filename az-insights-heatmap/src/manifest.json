{
    "name": "AZ Insights Heatmap",
    "version": "0.0.2",
    "manifest_version": 3,
    "description": "Changes color of Application Insights tiles in the Azure portal depending on health percentage.",
    "homepage_url": "https://github.com/andrewiankidd/BrowserExtensions/tree/master/az-insights-heatmap",
    "icons": {
        "16": "icons/logo16.png",
        "48": "icons/logo48.png",
        "128": "icons/logo128.png"
    },
    "action": {
        "default_popup": "main/main.html"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "az-insights-heatmap@andrewkidd.co.uk",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [{
        "matches": [
            "https://portal.azure.com/*"
        ],
        "js": [
            "inject/inject.js"
        ],
        "run_at": "document_idle"
    }]
}

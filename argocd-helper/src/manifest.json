{
    "name": "ArgoCD Helper",
    "version": "0.0.0.1",
    "manifest_version": 3,
    "description": "Quality-of-life tweaks for the ArgoCD UI: autofill delete confirmations and a 'Cancel & Sync' button.",
    "homepage_url": "https://github.com/andrewiankidd/BrowserExtensions/tree/master/argocd-helper",
    "icons": {
        "16": "icons/logo16.png",
        "32": "icons/logo32.png",
        "48": "icons/logo48.png",
        "128": "icons/logo128.png"
    },
    "action": {
        "default_popup": "main/main.html"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "argocd-helper@andrewkidd.co.uk",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "storage"
    ],
    "content_scripts": [{
        "matches": [
            "*://*/*"
        ],
        "include_globs": [
            "*argocd*"
        ],
        "js": [
            "inject/inject.js"
        ],
        "run_at": "document_idle"
    }]
}
